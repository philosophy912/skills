#!/usr/bin/env bash
# catva — cat-video-analyzer 命令包装器
#
# 作用：自动把 PYTHONPATH 指向 skill 目录，使 `python -m scripts.run` 可用，
#       这样调用方（agent）无需关心工作目录或模块搜索路径。
# 调用：bash "${CLAUDE_PLUGIN_ROOT}/skills/cat-video-analyzer/scripts/catva" <子命令> [...]
set -euo pipefail

# 定位本脚本所在目录的上一级 = skill 根目录（含 scripts/ 包）
SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

PYTHONPATH="$SKILL_DIR${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m scripts.run "$@"
